{
  "compilerOptions": {
    "target": "ESNext",
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": "./",
    "paths": {
      "@shared/*": ["shared/*"],
      "@main/*":   ["electron/main/*"]
    }
  },
  "include": ["package.json", "electron", "shared"],
  "exclude": ["shared/__tests__", "shared/types/reedy.ts", "shared/utils/vector.ts"]
}
