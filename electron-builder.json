{
  "appId": "com.mnemo.app",
  "productName": "Mnemo",
  "executableName": "Mnemo",
  "copyright": "copyright ©2026 Mnemo",
  "asar": true,
  "compression": "maximum",
  "npmRebuild": false,
  "buildDependenciesFromSource": true,
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "icon": "build/icon.ico",
  "files": ["dist"],
  "extraMetadata": {
    "name": "mnemo",
    "productName": "Mnemo",
    "description": "Mnemo multi-cloud desktop file manager",
    "author": {
      "name": "Mnemo",
      "email": "lllll081926i@users.noreply.github.com"
    }
  },
  "extraResources": [
    { "from": "./static/engine/aria2.conf", "to": "./engine/aria2.conf" },
    { "from": "./static/crx", "to": "./crx" }
  ],
  "mac": {
    "icon": "icon.icns",
    "type": "distribution",
    "artifactName": "mnemo-${version}-mac-${arch}.${ext}",
    "darkModeSupport": true,
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "category": "public.app-category.utilities",
    "entitlements": "./build/entitlements.mac.plist",
    "entitlementsInherit": "./build/entitlements.mac.plist",
    "extraResources": [
      { "from": "./static/images/icon.icns", "to": "./images/icon.icns" },
      { "from": "./static/images/icon_30x30.png", "to": "./images/icon_30x30.png" },
      { "from": "./static/images/icon_64x64.png", "to": "./images/icon_64x64.png" },
      { "from": "./static/engine/darwin/${arch}", "to": "./engine/darwin/${arch}" }
    ],
    "target": [
      { "target": "dmg", "arch": ["x64", "arm64"] },
      { "target": "zip", "arch": ["x64", "arm64"] }
    ]
  },
  "linux": {
    "executableName": "mnemo",
    "icon": "icons",
    "synopsis": "Mnemo multi-cloud desktop file manager",
    "description": "Mnemo multi-cloud desktop file manager",
    "category": "Network",
    "desktop": {
      "entry": {
        "Name": "Mnemo",
        "GenericName": "Cloud File Manager",
        "Comment": "Mnemo multi-cloud desktop file manager",
        "StartupWMClass": "Mnemo"
      }
    },
    "artifactName": "mnemo-${version}-linux-${arch}.${ext}",
    "extraResources": [
      { "from": "./static/images/icon_30x30.png", "to": "./images/icon_30x30.png" },
      { "from": "./static/images/icon_64x64.png", "to": "./images/icon_64x64.png" },
      { "from": "./static/images/icon_256x256.png", "to": "./images/icon_256x256.png" },
      { "from": "./static/engine/linux/${arch}", "to": "./engine/linux/${arch}" }
    ],
    "target": [
      { "target": "AppImage", "arch": ["x64", "arm64"] },
      { "target": "deb", "arch": ["x64", "arm64"] },
      { "target": "pacman", "arch": ["x64", "arm64"] }
    ]
  },
  "deb": {
    "fpm": ["--deb-no-default-config-files"]
  },
  "win": {
    "executableName": "Mnemo",
    "icon": "build/icon.ico",
    "legalTrademarks": "Mnemo",
    "artifactName": "Mnemo-${version}-Setup-${arch}.${ext}",
    "requestedExecutionLevel": "asInvoker",
    "signAndEditExecutable": true,
    "extraResources": [
      { "from": "./static/images", "to": "./images" },
      { "from": "./static/engine/win32/${arch}", "to": "./engine/win32/${arch}", "filter": ["**/*", "!mpv{,/**}"] }
    ],
    "target": [{ "target": "nsis", "arch": ["x64", "arm64"] }]
  },
  "dmg": {
    "title": "Mnemo",
    "icon": "icon.icns",
    "window": { "width": 560, "height": 320 },
    "iconSize": 96,
    "contents": [
      { "x": 400, "y": 160, "type": "link", "path": "/Applications" },
      { "x": 160, "y": 160, "type": "file" }
    ]
  },
  "nsis": {
    "oneClick": false,
    "perMachine": true,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Mnemo",
    "uninstallDisplayName": "Mnemo",
    "installerIcon": "build/installerIcon.ico",
    "uninstallerIcon": "build/installerIcon.ico",
    "installerHeaderIcon": "build/installerIcon.ico",
    "include": "installer.nsh",
    "runAfterFinish": true
  },
  "publish": [
    {
      "owner": "lllll081926i",
      "repo": "Mnemo",
      "provider": "github",
      "releaseType": "release"
    }
  ]
}
