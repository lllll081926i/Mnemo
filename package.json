{
  "name": "mnemo",
  "productName": "Mnemo",
  "description": "Mnemo multi-cloud desktop file manager",
  "version": "0.1.5",
  "main": "dist/electron/main/index.js",
  "packageManager": "npm@11.18.0",
  "author": {
    "name": "lllll081926i",
    "email": "lllll081926i@users.noreply.github.com"
  },
  "homepage": "https://github.com/lllll081926i/Mnemo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lllll081926i/Mnemo.git"
  },
  "bugs": {
    "url": "https://github.com/lllll081926i/Mnemo/issues"
  },
  "license": "GPL-3.0",
  "scripts": {
    "secrets:generate": "node scripts/generate-secrets.mjs --mode=local",
    "predev": "node scripts/generate-secrets.mjs --mode=local",
    "dev": "vite",
    "prebuild": "node scripts/generate-secrets.mjs --mode=local",
    "typecheck:renderer": "vue-tsc --noEmit --pretty false",
    "typecheck:electron": "tsc -p tsconfig.node.json --noEmit --pretty false",
    "typecheck": "npm run typecheck:renderer && npm run typecheck:electron",
    "build": "npm run typecheck && vite build",
    "build:version": "node version.mjs",
    "build:electron": "npm run build && electron-builder",
    "build:test": "npm run build && electron-builder --dir",
    "build:mac": "npm run build && electron-builder --mac",
    "build:mac:signed": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=true electron-builder --mac",
    "build:linux": "npm run build && node build-linux.mjs",
    "build:windows": "npm run build && electron-builder --win",
    "build:all": "node build-all.mjs",
    "pretest": "node scripts/generate-secrets.mjs --mode=local",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "@arco-design/web-vue": "2.55.1",
    "@arco-themes/vue-gi-demo": "^0.0.48",
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/lib-storage": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "@noble/curves": "^2.2.0",
    "@opendataloader/pdf": "^2.4.7",
    "@types/crypto-js": "^4.2.2",
    "@types/fast-levenshtein": "^0.0.4",
    "@types/lodash": "^4.17.0",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.12.5",
    "@vitejs/plugin-vue": "^6.0.8",
    "ant-design-vue": "4.1.2",
    "aria2-lib": "^1.0.1",
    "artplayer": "^5.4.0",
    "artplayer-plugin-jassub": "^1.1.0",
    "axios": "^1.6.8",
    "consola": "^3.2.3",
    "crypto-js": "^4.2.0",
    "dashjs": "^5.1.1",
    "dayjs": "^1.11.10",
    "dexie": "^4.0.1",
    "dom-to-image": "^2.6.0",
    "electron": "40.10.6",
    "electron-builder": "^26.15.3",
    "electron-is": "^3.0.0",
    "electron-store": "8.2.0",
    "electron-updater": "^6.8.3",
    "fast-levenshtein": "^3.0.0",
    "fix-path": "^4.0.0",
    "fuzzysort": "^2.0.4",
    "hls.js": "^1.5.7",
    "jassub": "^1.7.15",
    "jschardet": "^3.1.2",
    "less": "^4.2.0",
    "lodash": "^4.17.21",
    "lucide-vue-next": "^1.0.0",
    "mime-types": "^2.1.35",
    "pdfjs-dist": "^4.10.38",
    "pinia": "^2.1.7",
    "semver": "^7.6.0",
    "typescript": "^5.4.4",
    "uuid": "^11.1.1",
    "viewerjs": "^1.11.6",
    "vite": "^7.3.6",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7",
    "vitest": "^3.2.7",
    "vue": "^3.5.40",
    "vue-tsc": "^2.2.12",
    "webdav": "5.9.0"
  },
  "debug": {
    "env": {
      "VITE_DEV_SERVER_HOSTNAME": "127.0.0.1",
      "VITE_DEV_SERVER_PORT": 5173,
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:5173"
    }
  },
  "keywords": [
    "mnemo",
    "cloud",
    "file-manager",
    "electron",
    "vite",
    "vue3",
    "pikpak",
    "onedrive",
    "dropbox",
    "gdrive"
  ],
  "dependencies": {
    "mpegts.js": "^1.8.0"
  }
}
