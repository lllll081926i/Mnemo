    "dev": "vite",
    "prebuild": "node scripts/generate-secrets.mjs --mode=local",
    "build": "node version.mjs && vue-tsc --noEmit && vite build",
    "build:version": "node version.mjs",
    "build:electron": "npm run build && electron-builder",
    "build:test": "npm run build && electron-builder --dir",
    "build:mac": "npm run build && electron-builder --mac",
    "build:mac:signed": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=true electron-builder --mac",
    "build:linux": "npm run build && node build-linux.mjs",
    "build:windows": "npm run build && electron-builder --win",
    "build:all": "node build-all.mjs",
    "pretest": "node scripts/generate-secrets.mjs --mode=local",
    "test": "vitest run electron/main/aria/__tests__ src/down/motrix-integration src/utils/__tests__/aria2EnginePolicy.test.ts src/utils/__tests__/aria2Rpc.test.ts"
